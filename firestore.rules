rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only authenticated users (admins) can read/write all data
    match /members/{id} {
      allow read, write: if request.auth != null;
    }
    match /trainers/{id} {
      allow read, write: if request.auth != null;
    }
    match /payments/{id} {
      allow read, write: if request.auth != null;
    }
    match /attendance/{id} {
      allow read, write: if request.auth != null;
    }
    match /dietPlans/{id} {
      allow read, write: if request.auth != null;
    }
    match /users/{id} {
      allow read, write: if request.auth != null && request.auth.uid == id;
    }
  }
}
